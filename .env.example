# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase — safe to expose client-side
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — SERVER-SIDE ONLY, never expose to the client.
# Required by every route under lib/auth, lib/engine, and most app/api
# routes for privileged reads/writes (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — required for any paid membership plan. Without these,
# createPaymentIntent() will throw rather than silently returning a
# broken payment intent (see lib/engine/treasury.js).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
